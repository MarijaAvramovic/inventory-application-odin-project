<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('head') %>
</head>
<body>

 <%- include('nav') %>

  <main>
    <div class="tool-form-card">
  <h1>Update Tool</h1>
  <% if (errors && errors.length > 0) { %>
  <ul class="error">
    <% errors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>
  

<form action="/tools/update/<%= tool.id %>" method="POST">
    
   <label for="name">Name</label>
  <input type="text" name="name" id="name" value="<%= oldInput?.name || tool.name %>" required>

  <label for="url">URL</label>
  <input type="url" name="url" id="url" value="<%= oldInput?.url || tool.ahref %>" required>

  <label for="category">Category</label>
  <select name="category" id="category" required>
    <option value="">Select a category</option>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>" 
        <%= (oldInput?.category == cat.id) || (tool.category_id == cat.id && !oldInput) ? "selected" : "" %>>
        <%= cat.name %>
      </option>
    <% }) %>
  </select>

  <button type="submit">Update Tool</button>
  </form>
</div>
  </main>


  
  <footer>
     <%- include('footer') %>
  </footer>

</body>
</html>