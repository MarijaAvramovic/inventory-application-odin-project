  <% categories.forEach(category => { %>
        <div class="grid-item category">
            

          <h2><%= category.name %></h2>
          
              <a href="/categories/<%= category.id %>">View</a>
              <!-- <a href="/categories/edit/<%= category.id %>">Edit</a> -->
            
           <button onclick="if(confirm('Are you sure you want to delete this category?')) { window.location.href = '/categories/delete/<%= category.id %>' }">Delete</button>
        </div>
      <% }) %>  