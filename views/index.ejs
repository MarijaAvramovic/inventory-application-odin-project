<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('head') %>
</head>
<body>

 <%- include('nav') %>

  <main>
    <h1 style="text-align:center; margin-bottom:40px;">The Odin Project Inventory App</h1>
    
   <div style="text-align:center">   <h2>Categories</h2></div>
    <div class="grid-container">
     <% categories.forEach(category => { %>
        <div class="grid-item category">
            <a href="/categories/<%= category.id %>"><h2><%= category.name %></h2></a>

           
        </div>
      <% }) %>  

    </div>
    
 
    <div style="text-align:center">   <h2>Tools</h2></div>
    <div class="grid-container">
      <%- include('partials/tools', { tools: tools }) %>

    </div>
  </main>


  
  <footer>
     <%- include('footer') %>
  </footer>

</body>
</html>