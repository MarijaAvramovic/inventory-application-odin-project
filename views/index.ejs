<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('head') %>
</head>
<body>

 <%- include('nav') %>

  <main>
    <h1 style="text-align:center; margin-bottom:40px;">The Odin Project Inventory App</h1>
    
   <div style="text-align:center">   <h2>Categories</h2></div>
    <div class="flex-container">
   
      <% categories.forEach(category => { %>
        <div class="flex-item">
          <h2><%= category.name %></h2>
          <p>hello</p>
        </div>
      <% }) %>    
    </div>
    
 
    <div style="text-align:center">   <h2>Tools</h2></div>
    <div class="grid-container">
      <% tools.forEach(tool => { %>
        <div class="grid-item">
          <h3><%= tool.name %></h3>
          <p><%= tool.description %></p>
        </div>
      <% }) %>
    </div>
  </main>


  
  <footer>
     <%- include('footer') %>
  </footer>

</body>
</html>